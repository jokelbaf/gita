DATABASE_URL="postgresql://gita:gita@localhost:5432/gita?schema=public"

# Better Auth secret. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Public base URL of the app (used for OAuth callbacks and cookies).
BETTER_AUTH_URL="http://localhost:1791"

# GitHub OAuth app credentials (https://github.com/settings/developers).
# Authorization callback URL: <BETTER_AUTH_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# 32-byte key (base64 or hex) that encrypts user git access tokens at rest
# (AES-256-GCM).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CREDENTIAL_ENCRYPTION_KEY=""

# Dragonfly/Redis connection for the render and rate-limit cache.
# Local dev: docker run -d -p 6379:6379 docker.dragonflydb.io/dragonflydb/dragonfly
REDIS_URL="redis://localhost:6379"

# Optional: a real GitHub personal access token so `pnpm db:seed` gives the
# seeded user/repo instances live data.
SEED_GITHUB_TOKEN=""

# Production db
PG_USER="gita"
PG_PASSWORD="gita"
PG_DB="gita"
